---
const { title } = Astro.props;
---

<div class="center-wrap card-wrap">
  <div class="relative w-full block text-center">
    <h4
      class="mb-5 text-4xl text-white font-Cherry-Bomb"
    >
      {title}
    </h4>
    <div class="w-full h-auto flex flex-col gap-2">
      <slot />
    </div>
    <a
      href="#"
      class="btn font-extrabold mt-5 rounded-sm h-11 uppercase p-[0_20px] items-center justify-center text-center bg-white text-pink-600"
    >
      Aceptar
    </a>
    {
      title === "Log in" && (
        <p class="text-center mt-1 font-bold text-md font-signika">
          <a
            href="#0"
            class="text-light-dark hover:text-tertiary"
          >
            ¿Olvidaste tu contraseña?
          </a>
        </p>
      )
    }
  </div>
</div>

<style>
  p {
    line-height: 1.7;
  }

  .center-wrap {
    transform: translate3d(0, -50%, 35px) perspective(100px);
  }

  .btn {
    font-size: 16px;
    -webkit-transition: all 200ms linear;
    transition: all 200ms linear;
    letter-spacing: 1px;
    display: -webkit-inline-flex;
    display: -ms-inline-flexbox;
    display: inline-flex;
    -webkit-align-items: center;
    -moz-align-items: center;
    -ms-align-items: center;
    -webkit-justify-content: center;
    -moz-justify-content: center;
    -ms-justify-content: center;
    -ms-flex-pack: center;
    border: none;
    box-shadow: inset 0 0 7px 1px rgba(230, 0, 118, 0.5);
  }

  .btn:active,
  .btn:focus {
    box-shadow: inset 0 0 7px 2px rgba(230, 0, 118, 0.6);
  }

  .btn:hover {
    box-shadow: inset 0 0 7px 2px rgba(230, 0, 118, 0.6);
  }
</style>
